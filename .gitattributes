# Force Unix LF line endings for all shell scripts and Python files
# Prevents CRLF corruption on Windows/WSL2 workflows
*.sh    text eol=lf
*.py    text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.env   text eol=lf

# Binary files — no line ending conversion
*.png   binary
*.jpg   binary
*.pdf   binary
*.gz    binary
*.zip   binary
